    {
      "parameters": {
        "jsCode": "// 1. Get all input items (uploaded image URLs)\nconst items = $input.all();\n\n// 2. Get the HTML content from a separate variable or hardcoded (you can change this part)\nconst originalHtml = $node['Webhook1'].json.body.PostContent\n\n// 3. Extract new image URLs\nlet imageUrls = []\nitems.forEach(item => {\n  if(item.json.image_url){\n    imageUrls.push(item.json.image_url) \n  }\n});\n\nlet updatedHtml=originalHtml\nif(imageUrls.length){\n  \n// 4. Replace each <img src=\"...\"> one-by-one\nlet index = 0;\n updatedHtml = originalHtml.replace(\n  /<img[^>]+src=['\"]([^'\"]+)['\"][^>]*>/g,\n  (match, oldUrl) => {\n    const newUrl = imageUrls[index++];\n    return newUrl ? match.replace(oldUrl, newUrl) : match;\n  }\n);\n} \n\n// 5. Return the updated HTML only\nreturn [\n  {\n    json: {\n      updatedPostContent: updatedHtml\n    }\n  }\n];\n"
      },
