    {
      "parameters": {
        "jsCode": "const html = $node[\"validate_payload\"].json.PostContent;\n\n// Match both single and double quotes in src attribute\nconst matches = [...html.matchAll(/<img[^>]+src=['\"]([^'\"]+)['\"]/g)];\n\nconst urls = matches.map(m => m[1]);\n\nreturn urls.map(url => ({ json: { imageUrl: url } }));\n"
      },
